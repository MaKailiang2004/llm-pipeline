PROJECT_NAME=mini-rag-poc
LOG_LEVEL=INFO
HF_ENDPOINT=https://hf-mirror.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=raw_reviews
KAFKA_LABEL_TOPIC=rag_auto_labels
KAFKA_GROUP_ID=rag_poc_group

# HDFS
HDFS_HOST=localhost
# 多机 Ray 时，DataNode 需公布 hostname 供远端 Worker 连接块传输端口 9866。
# 设为 datanode 时：Docker 内由 DNS 解析，host/远端需在 /etc/hosts 添加 datanode。也可设为宿主机 IP（如 10.60.41.44）。
HDFS_DATANODE_ANNOUNCE_HOST=
HDFS_PORT=9000
HDFS_BASE_PATH=/data/rag_poc
HDFS_RAW_PATH=/data/rag_poc/raw
HDFS_PROCESSED_PATH=/data/rag_poc/processed
HDFS_LABEL_PATH=/data/rag_poc/labels

# Spark
SPARK_MASTER=spark://localhost:7077
SPARK_APP_NAME=rag-kafka-to-hdfs
SPARK_BATCH_INTERVAL_SECONDS=30
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints/rag-poc

# Ray
RAY_IMAGE_NAME=llm-pipeline/ray:latest
RAY_ADDRESS=ray://localhost:10001
RAY_NAMESPACE=rag-labeling
RAY_NUM_WORKERS=2
RAY_INFERENCE_BATCH_SIZE=8
RAY_READ_BATCH_SIZE=128
#
# Multi-host Ray (optional):
# - Keep server 1 as the Ray head / Kafka / HDFS host.
# - Leave RAY_HEAD_NODE_IP empty to auto-detect on server 1, or set it
#   explicitly to a private/public IP that server 2 can reach.
# - On server 2, set RAY_CLUSTER_JOIN_ADDRESS to "<server1-ip>:6379" before
#   starting docker-compose.ray-worker.yml.
RAY_HEAD_NODE_IP=
RAY_HEAD_PORT=6379
RAY_HEAD_CLIENT_PORT=10001
RAY_DASHBOARD_PORT=8265
RAY_CLUSTER_JOIN_ADDRESS=host.docker.internal:6379
# On server 1 with a single GPU, keep only the head GPU-enabled.
RAY_HEAD_VISIBLE_GPUS=all
RAY_WORKER_VISIBLE_GPUS=none
RAY_WORKER2_VISIBLE_GPUS=none
RAY_WORKER_NODE_IP=

# Step 4 runtime addresses inside the ray-head container.
# With the default host-networked ray-head, localhost reaches Kafka/HDFS ports
# published by server 1. Override only if your primary server uses a different
# routable address.
STEP4_HDFS_HOST=localhost
STEP4_HDFS_PORT=9000
STEP4_HDFS_SILVER_PATH=hdfs://localhost:9000/data/silver/
STEP4_HDFS_GOLD_LABELED_PATH=hdfs://localhost:9000/data/gold/labeled/
STEP4_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
STEP4_RAY_ADDRESS=auto

# Ray Task Scheduling - LLM (vLLM Offline) resource control
# Each Offline vLLM Actor claims GPUs via Ray resources (default: 1 GPU / actor).
RAY_LABEL_NUM_GPUS_PER_ACTOR=1
# Optional: manually cap actor count (default: GPU_count / num_gpus_per_actor)
RAY_LABEL_ACTOR_COUNT=1
# Step 4 I/O: 1=Ray Data 直接读 HDFS（流式，避免 toPandas 全量加载），0=Spark I/O；Ray Data 失败时自动回退到 Spark
USE_RAY_DATA_HDFS_IO=0
RAY_INFERENCE_BATCH_SIZE=32
RAY_LLM_MAX_BATCHED_TOKENS=32768

# vLLM (Offline batched inference)
# If you pre-download with scripts/download_model.sh, point to the local path below.
VLLM_MODEL_NAME=/workspace/models/Qwen2.5-3B-Instruct
VLLM_MAX_TOKENS=128
VLLM_TEMPERATURE=0.0
VLLM_TOP_P=1.0
VLLM_OFFLINE_GPU_MEMORY_UTILIZATION=0.92
VLLM_OFFLINE_MAX_NUM_SEQS=128
VLLM_OFFLINE_MAX_MODEL_LEN=1024
VLLM_OFFLINE_DTYPE=bfloat16
VLLM_OFFLINE_TRUST_REMOTE_CODE=0
# Performance-oriented toggles (optional)
VLLM_OFFLINE_ENABLE_PREFIX_CACHING=1
VLLM_OFFLINE_ENFORCE_EAGER=0
VLLM_OFFLINE_DISABLE_LOG_STATS=1
HUGGING_FACE_HUB_TOKEN=

# File paths
INPUT_JSONL_PATH=./data/input_documents.jsonl

# ETL dedup skew mitigation (two-phase salt)
ETL_USE_SALTED_DEDUP=1
ETL_DEDUP_SALT_BUCKETS=100

# Vectorization
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
HDFS_GOLD_EMBEDDINGS_PATH=hdfs://localhost:9000/data/gold/embeddings/
RAY_EMBED_BATCH_SIZE=32
RAY_EMBED_CONCURRENCY=2
RAY_EMBED_GPU_CONCURRENCY=1
RAY_EMBED_NUM_GPUS_PER_WORKER=0.5
RAY_EMBED_MAX_LENGTH=512
RAY_EMBED_OOM_FALLBACK_BATCH=16
RAY_EMBED_USE_PLACEMENT_GROUP=0
RAY_CHUNK_MAX_CHARS=700
RAY_CHUNK_MAX_SENTENCES=6

# Continuous Evaluation
HDFS_GOLD_LABELED_PATH=hdfs://localhost:9000/data/gold/labeled/
QUALITY_SAMPLE_SIZE=100
QUALITY_PASS_THRESHOLD=4.0
QUALITY_RANDOM_SEED=42
JUDGE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
JUDGE_API_KEY=sk-80028287729a440ea1f67f4709e27bea
JUDGE_MODEL_NAME=qwen-plus
JUDGE_TIMEOUT_SECONDS=60
JUDGE_MAX_RETRIES=3
JUDGE_RETRY_BACKOFF_SECONDS=2
JUDGE_CONCURRENCY=8

# vLLM HTTP Server 压测与监控 (tools/vllm_bench)
# 用于独立部署 vllm serve 时的启动-预热-压测-监控流程
MODEL_PATH=/workspace/models/Qwen2.5-3B-Instruct
MAX_MODEL_LEN=4096
EXPECTED_QPS=20
TEST_DATASET_PATH=tools/vllm_bench/sample_dataset.jsonl
VLLM_BASE_URL=http://localhost:8000/v1
